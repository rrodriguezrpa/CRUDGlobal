<Window x:Class="Empleados.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gestion de Empleados" Height="640" Width="1040"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BrandLight}">
    <DockPanel>
        <!-- Cabecera -->
        <Border DockPanel.Dock="Top" Background="{StaticResource BrandPrimary}" Padding="18,12">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Gestion de Empleados" Foreground="White"
                               FontSize="20" FontWeight="Bold"/>
                    <TextBlock Text="RRHH" Foreground="#9DB8D2" FontSize="20" Margin="8,0,0,0"/>
                </StackPanel>
                <TextBlock x:Name="SessionLabel" HorizontalAlignment="Right" VerticalAlignment="Center"
                           Foreground="#9DB8D2" FontSize="12"/>
            </Grid>
        </Border>

        <!-- Barra de herramientas -->
        <Border DockPanel.Dock="Top" Background="White" Padding="14,10" BorderBrush="#E0E4EA" BorderThickness="0,0,0,1">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Buscar:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBox x:Name="SearchBox" Width="200" Height="28" VerticalContentAlignment="Center"
                             KeyDown="SearchBox_KeyDown"/>
                    <TextBlock Text="Departamento:" VerticalAlignment="Center" Margin="14,0,6,0"/>
                    <ComboBox x:Name="DeptFilter" Width="150" Height="28" SelectedIndex="0"/>
                    <Button x:Name="BtnBuscar" Content="Buscar" Click="BtnBuscar_Click" Margin="10,0,0,0"/>
                    <Button x:Name="BtnRefrescar" Content="Refrescar" Click="BtnRefrescar_Click"
                            Background="#6C7A89"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button x:Name="BtnNuevo" Content="Nuevo" Click="BtnNuevo_Click" Background="#2E7D5B"/>
                    <Button x:Name="BtnEditar" Content="Editar" Click="BtnEditar_Click"/>
                    <Button x:Name="BtnEliminar" Content="Eliminar" Click="BtnEliminar_Click"
                            Background="{StaticResource BrandDanger}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Pie de paginacion -->
        <Border DockPanel.Dock="Bottom" Background="White" Padding="14,8" BorderBrush="#E0E4EA" BorderThickness="0,1,0,0">
            <Grid>
                <TextBlock x:Name="TotalLabel" VerticalAlignment="Center" Foreground="#55606B"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock Text="Filas:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <ComboBox x:Name="PageSizeCombo" Width="60" Height="28" SelectedIndex="0"
                              SelectionChanged="PageSizeCombo_SelectionChanged">
                        <ComboBoxItem Content="5"/>
                        <ComboBoxItem Content="10"/>
                        <ComboBoxItem Content="20"/>
                    </ComboBox>
                    <Button x:Name="BtnPrev" Content="Anterior" Click="BtnPrev_Click" Background="#6C7A89"/>
                    <TextBlock x:Name="PageLabel" VerticalAlignment="Center" Margin="8,0" MinWidth="120"
                               TextAlignment="Center"/>
                    <Button x:Name="BtnNext" Content="Siguiente" Click="BtnNext_Click" Background="#6C7A89"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Tabla -->
        <DataGrid x:Name="Grid" Margin="14" AutoGenerateColumns="False" IsReadOnly="True"
                  SelectionMode="Single" HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                  RowHeight="32" Background="White" BorderBrush="#E0E4EA"
                  CanUserAddRows="False" CanUserDeleteRows="False"
                  MouseDoubleClick="Grid_MouseDoubleClick">
            <DataGrid.Columns>
                <DataGridTextColumn Header="N. Empleado" Binding="{Binding NumeroEmpleado}" Width="110"/>
                <DataGridTextColumn Header="Nombre" Binding="{Binding Nombre}" Width="120"/>
                <DataGridTextColumn Header="Apellidos" Binding="{Binding Apellidos}" Width="180"/>
                <DataGridTextColumn Header="DNI" Binding="{Binding Dni}" Width="100"/>
                <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="*"/>
                <DataGridTextColumn Header="Departamento" Binding="{Binding Departamento}" Width="120"/>
                <DataGridTextColumn Header="Puesto" Binding="{Binding Puesto}" Width="160"/>
                <DataGridTextColumn Header="Salario" Binding="{Binding Salario, StringFormat=N0}" Width="90"/>
                <DataGridCheckBoxColumn Header="Activo" Binding="{Binding Activo}" Width="60"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
