<Window x:Class="Empleados.Desktop.EmpleadoDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Empleado" Width="440" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="White">
    <StackPanel Margin="22">
        <TextBlock x:Name="TituloLabel" Text="Nuevo empleado" FontSize="18" FontWeight="Bold"
                   Foreground="#1F3A5F" Margin="0,0,0,16"/>

        <TextBlock Text="Nombre" Margin="0,0,0,3"/>
        <TextBox x:Name="TxtNombre" Height="28" VerticalContentAlignment="Center" Margin="0,0,0,10"/>

        <TextBlock Text="Apellidos" Margin="0,0,0,3"/>
        <TextBox x:Name="TxtApellidos" Height="28" VerticalContentAlignment="Center" Margin="0,0,0,10"/>

        <TextBlock Text="DNI (8 digitos + letra)" Margin="0,0,0,3"/>
        <TextBox x:Name="TxtDni" Height="28" VerticalContentAlignment="Center" Margin="0,0,0,10"/>

        <TextBlock Text="Email" Margin="0,0,0,3"/>
        <TextBox x:Name="TxtEmail" Height="28" VerticalContentAlignment="Center" Margin="0,0,0,10"/>

        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Departamento" Margin="0,0,0,3"/>
                <ComboBox x:Name="CmbDepartamento" Height="28"/>
            </StackPanel>
            <StackPanel Grid.Column="2">
                <TextBlock Text="Salario (EUR)" Margin="0,0,0,3"/>
                <TextBox x:Name="TxtSalario" Height="28" VerticalContentAlignment="Center"/>
            </StackPanel>
        </Grid>

        <TextBlock Text="Puesto" Margin="0,0,0,3"/>
        <TextBox x:Name="TxtPuesto" Height="28" VerticalContentAlignment="Center" Margin="0,0,0,10"/>

        <CheckBox x:Name="ChkActivo" Content="Empleado activo" IsChecked="True" Margin="0,4,0,16"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="BtnCancelar" Content="Cancelar" Click="BtnCancelar_Click"
                    Background="#6C7A89" Foreground="White" BorderThickness="0"
                    Padding="14,7" Margin="4,0" Cursor="Hand"/>
            <Button x:Name="BtnGuardar" Content="Guardar" Click="BtnGuardar_Click"
                    Background="#2E7D5B" Foreground="White" BorderThickness="0"
                    Padding="14,7" Margin="4,0" Cursor="Hand" FontWeight="SemiBold"/>
        </StackPanel>
    </StackPanel>
</Window>
