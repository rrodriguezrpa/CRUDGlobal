<Application x:Class="Empleados.Desktop.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Empleados.Desktop">
    <Application.Resources>
        <!-- Paleta corporativa sobria -->
        <SolidColorBrush x:Key="BrandPrimary"   Color="#1F3A5F"/>
        <SolidColorBrush x:Key="BrandAccent"    Color="#2D6A9F"/>
        <SolidColorBrush x:Key="BrandLight"     Color="#F4F6F9"/>
        <SolidColorBrush x:Key="BrandDanger"    Color="#B23A48"/>

        <Style TargetType="Button">
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="Background" Value="{StaticResource BrandAccent}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Application.Resources>
</Application>
