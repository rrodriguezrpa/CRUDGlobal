# Copia a .env y ajusta. Variables leidas por la API al arrancar.

# Clave de API exigida en el header X-Api-Key (default: demo-uipath-2026)
DEMO_API_KEY=demo-uipath-2026

# URL publica del tunel; se anade como server en el documento OpenAPI.
# Ej. https://xxxx.ts.net  (Tailscale Funnel) o el dominio de Cloudflare.
PUBLIC_BASE_URL=

# Origenes CORS permitidos, separados por comas. Vacio = AllowAnyOrigin.
# Ej. https://mi-front.example.com,https://otro.example.com
ALLOWED_ORIGINS=
